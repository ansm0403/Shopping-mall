# 서버 설정
PROTOCOL=http
HOST=localhost:4000
PORT=4000

# PostgreSQL 설정
# EC2 배포 시 POSTGRES_HOST/PORT는 docker-compose가 오버라이드함 (값: postgres, 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=your-username
POSTGRES_PASSWORD=your-password
POSTGRES_DB=your-database

# Redis 설정
# EC2 배포 시 REDIS_HOST/PORT는 docker-compose가 오버라이드함 (값: redis, 6379)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 설정
JWT_SECRET=your-jwt-secret-key-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here

# 이메일 설정 (Gmail 또는 Naver 중 선택)

# === Gmail 사용하는 경우 ===
# 1. Google 계정에서 2단계 인증 활성화
# 2. 앱 비밀번호 생성 (https://myaccount.google.com/apppasswords)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_SECURE=false
# MAIL_USER=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# === Naver 메일 사용하는 경우 ===
MAIL_HOST=smtp.naver.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-naver-id
MAIL_PASSWORD=your-naver-password

# 공통 설정
MAIL_FROM_NAME=Shopping Mall
MAIL_FROM_ADDRESS=your-email@naver.com

# 프론트엔드 URL (이메일 인증 링크 생성에 사용됨 — 필수, fallback 없음)
# 로컬: http://localhost:3000
# 운영(EC2): Vercel production alias (ex: https://your-app.vercel.app)
# ※ preview/hash URL(ex: -gne675cog-.vercel.app) 사용 금지 — 배포마다 바뀜
FRONTEND_URL=http://localhost:3000

# CORS 허용 origin 목록 (콤마 구분, FRONTEND_URL과 별도 관리)
# FRONTEND_URL은 이메일 링크용, CORS_ORIGINS는 브라우저 요청 허용용으로 역할 분리
# 로컬: http://localhost:3000
# 운영(EC2): https://your-app.vercel.app
# 운영은 Vercel 프록시 방식이라 실질적으로 CORS가 발생하지 않지만 명시 권장
CORS_ORIGINS=http://localhost:3000

# 포트원 V2
# 포트원 콘솔(https://admin.portone.io) → 결제 연동 → API & SDK → V2 API Secret
PORTONE_API_SECRET=your-portone-v2-api-secret
